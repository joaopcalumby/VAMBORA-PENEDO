# ==============================================
# Vambora Penedo — Variáveis de Ambiente
# ==============================================
#
# 1. Crie um arquivo .env
# 2. Ajuste os valores conforme o ambiente de deploy

DATABASE_URL=sqlite:///./vambora.db
BACKEND_CORS_ORIGINS=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=coloque-seu-token-do-mapbox
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=troque-por-uma-string-forte